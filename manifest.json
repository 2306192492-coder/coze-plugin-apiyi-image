{
  "name": "API易图像生成",
  "version": "2.0.0",
  "description": "调用API易的图像生成模型，支持文生图和图生图编辑，支持Nano Banana、Flux、GPT-Image等",
  "author": "公子",
  "inputs": [
    {
      "name": "mode",
      "type": "string",
      "description": "生成模式",
      "required": false,
      "default": "text2img",
      "options": [
        {"label": "文生图", "value": "text2img"},
        {"label": "图生图", "value": "img2img"}
      ]
    },
    {
      "name": "prompt",
      "type": "string",
      "description": "图像描述（如：一只可爱的猫咪在花园里玩耍）",
      "required": true
    },
    {
      "name": "image_url",
      "type": "string",
      "description": "原图URL（图生图模式必填）",
      "required": false
    },
    {
      "name": "mask_url",
      "type": "string",
      "description": "遮罩图URL（可选，白色区域为编辑区域）",
      "required": false
    },
    {
      "name": "model",
      "type": "string",
      "description": "模型选择",
      "required": false,
      "default": "gpt-4o-image",
      "options": [
        {"label": "GPT-4o Image（推荐）", "value": "gpt-4o-image"},
        {"label": "Nano Banana Pro", "value": "gemini-3-pro-image"},
        {"label": "GPT-Image-1", "value": "gpt-image-1"},
        {"label": "Flux Pro", "value": "black-forest-labs/flux-pro-v1.1"},
        {"label": "Flux Max（支持编辑）", "value": "black-forest-labs/flux-kontext-max"},
        {"label": "DALL-E 3", "value": "dall-e-3"},
        {"label": "DALL-E 2（支持编辑）", "value": "dall-e-2"}
      ]
    },
    {
      "name": "size",
      "type": "string",
      "description": "图片尺寸",
      "required": false,
      "default": "1024x1024",
      "options": [
        {"label": "正方形 1024x1024", "value": "1024x1024"},
        {"label": "横版 1792x1024", "value": "1792x1024"},
        {"label": "竖版 1024x1792", "value": "1024x1792"},
        {"label": "横版 1920x1080", "value": "1920x1080"},
        {"label": "竖版 1080x1920", "value": "1080x1920"}
      ]
    },
    {
      "name": "n",
      "type": "number",
      "description": "生成图片数量（1-4张）",
      "required": false,
      "default": 1
    }
  ],
  "outputs": [
    {
      "name": "success",
      "type": "boolean",
      "description": "是否成功"
    },
    {
      "name": "image_urls",
      "type": "array",
      "description": "生成的图片URL列表"
    },
    {
      "name": "error",
      "type": "string",
      "description": "错误信息（失败时）"
    }
  ],
  "credentials": [
    {
      "name": "apiyi_api_key",
      "type": "string",
      "description": "API易平台的API Key",
      "required": true
    }
  ]
}
